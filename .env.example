# Contact form email delivery (Gmail SMTP via Nodemailer)
# Copy this file to `.env.local` and fill in real values.

# The Gmail address that will SEND the messages.
GMAIL_USER=your-address@gmail.com

# A Google *App Password* (NOT your normal Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the account)
GMAIL_APP_PASSWORD=your-16-char-app-password

# Where contact-form submissions are delivered.
# Defaults to the site email if omitted.
CONTACT_TO=marc@acoretechnology.com
